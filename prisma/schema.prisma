model AiMeeting {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  botId           String?  @map("bot_id")
  meetingUrl      String   @map("meeting_url")
  meetingName     String?  @map("meeting_name")
  platform        String?  // zoom, google_meet, teams
  status          String   @default("pending") // pending, joined, recording, completed, failed
  
  // Recording data
  videoUrl        String?  @map("video_url")
  audioUrl        String?  @map("audio_url")
  videoBlob       Bytes?   @map("video_blob")
  audioBlob       Bytes?   @map("audio_blob")
  duration        Int?     // in seconds
  
  // Transcription
  transcript      Json?    // Full transcript array
  speakers        String[] // Unique speakers
  
  summary         String?  @db.Text
  actionItems     Json?    @map("action_items")
  keyPoints       Json?    @map("key_points")
  s3VideoKey      String?   @map("s3_video_key")
  s3AudioKey      String?   @map("s3_audio_key")
  s3UploadedAt    DateTime? @map("s3_uploaded_at")
 
  startedAt       DateTime? @map("started_at")
  endedAt         DateTime? @map("ended_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Webhook data
  webhookData     Json?     @map("webhook_data")
   processedEventIds      String[] @default([]) 
  lastWebhookTimestamp   String?  
  errorMessage    String?   @map("error_message")
  transcriptionProvider  String   @default("assemblyai")
  assemblyaiTranscriptId String?
  sourceMeetingId String?  @unique   // links to Meeting.id
  scheduledFor    DateTime? 
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages    ChatMessage[]

  @@index([userId])
  @@index([botId])
  @@index([status])
  @@map("ai_meetings")  // Better table name
}

model ChatMessage {
  id          String   @id @default(cuid())
  meetingId   String   @map("meeting_id")
  userId      String   @map("user_id")
  role        String   // user, assistant, system
  content     String   @db.Text
  contextUsed Boolean  @default(false) @map("context_used")
  createdAt   DateTime @default(now()) @map("created_at")
  
  aiMeeting   AiMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([userId])
  @@map("chat_messages")
}

model File {
  id           String      @id @default(cuid())
  userId       String
  originalName String
  storageKey   String      @unique
  mimeType     String
  size         Int
  ext          String
  uploadVia    UploadSource
  url          String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  notifications Notification[]
  // NEW: Team and visibility fields
  teamId       String?     // If null, it's personal file
  team         Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
