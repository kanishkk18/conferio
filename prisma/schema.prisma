  type        String   // TASK_ASSIGNED, PAGE_ASSIGNED, MEETING_SCHEDULED, CALL_INCOMING, FILE_ASSIGNED, TIME_APPROVAL_NEEDED, etc.
  title       String
  body        String
  data        Json?    // Contextual data: { taskId, boardId, pageId, meetingId, etc. }
  
  // Related entities (optional links)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  pageId      String?
  page        Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)
  meetingId   String?
  meeting     Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  fileId      String?
  file        File?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  callId      String?
  call        Call?    @relation(fields: [callId], references: [id], onDelete: SetNull)

  // Delivery tracking
  channels    String[] // ["in_app", "email", "slack", "discord", "push"]
  read        Boolean  @default(false)
  readAt      DateTime?
  clicked     Boolean  @default(false)
  clickedAt   DateTime?
  
  // For actionable notifications
  actions     Json?    // [{ label: "Approve", action: "approve_time", endpoint: "/api/..." }]
  
  createdAt   DateTime @default(now())
  expiresAt   DateTime? // Auto-archive after date
  
  @@index([userId, read, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}


model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Channel preferences by notification type
  preferences     Json     // { TASK_ASSIGNED: { in_app: true, email: true, slack: false }, ... }
  
  quietHoursStart Int?     // 0-23, null if disabled
  quietHoursEnd   Int?     // 0-23
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("notification_preferences")
}


model VideoConference {
  id              String   @id @default(cuid())
  roomId          String   @unique
  title           String   @default("Untitled Meeting")
  description     String?
  hostId          String
  host            User     @relation("VideoConferenceHost", fields: [hostId], references: [id], onDelete: Cascade)

  password        String?
  requireApproval Boolean  @default(false)
  isPublic        Boolean  @default(false)

  backgroundType  String   @default("none")
  backgroundValue String?

  status          VMStatus @default(WAITING)
  startedAt       DateTime?
  endedAt         DateTime?

  participants    VMParticipant[]
  chatMessages    VMChatMessage[]
  waitingRoom     VMWaitingEntry[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([hostId])
  @@index([status])
  @@map("video_conferences")
}

enum VMStatus {
  WAITING
  ACTIVE
  ENDED
}

model VMParticipant {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?    @relation("VMParticipants", fields: [userId], references: [id], onDelete: SetNull)

  guestName   String?
  guestEmail  String?

  role        VMRole   @default(PARTICIPANT)
  joinedAt    DateTime @default(now())
  leftAt      DateTime?

  livekitIdentity String?

  @@unique([meetingId, livekitIdentity])
  @@index([meetingId])
  @@map("vm_participants")
}

enum VMRole {
  HOST
  CO_HOST
  PARTICIPANT
}

model VMChatMessage {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  senderId    String?
  senderName  String
  senderImage String?
  content     String   @db.Text
  type        VMChatType @default(TEXT)

  createdAt   DateTime @default(now())

  @@index([meetingId, createdAt])
  @@map("vm_chat_messages")
}

enum VMChatType {
  TEXT
  REACTION
  SYSTEM
}

model VMWaitingEntry {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     VideoConference @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName   String?
  guestEmail  String?
  requestedAt DateTime @default(now())
  status      String   @default("waiting")

  @@index([meetingId, status])
  @@map("vm_waiting_entries")
}



model VideoMeeting {
  id            String   @id @default(cuid())
  roomName      String   @unique
  title         String
  createdById   String
  createdBy     User     @relation("VideoMeetingCreator", fields: [createdById], references: [id], onDelete: Cascade)
  scheduledAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  settings      Json     @default("{}")
  chatLog       Json[]   @default([])
  participants  VideoMeetingParticipant[]
  recordings    VideoMeetingRecording[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdById])
  @@index([roomName])
  @@map("video_meetings")
}

model VideoMeetingParticipant {
  id         String       @id
  meetingId  String
  meeting    VideoMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId     String
  user       User         @relation("VideoMeetingParticipants", fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime     @default(now())
  leftAt     DateTime?
  duration   Int?
  role       String       @default("participant")
  deviceInfo Json?

  @@index([meetingId])
  @@index([userId])
  @@map("video_meeting_participants")
}

model VideoMeetingRecording {
  id         String       @id @default(cuid())
  meetingId  String
  meeting    VideoMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  s3Key      String
  startedAt  DateTime
  endedAt    DateTime?
  fileSize   BigInt?
  duration   Int?
  status     String       @default("pending")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([meetingId])
  @@map("video_meeting_recordings")
}


model Note {
  id          String   @id @default(cuid())
  title       String   @default("Untitled Note")
  content     Json?
  emoji       String?
  coverImage  String?
  authorId    String
  folderId    String?  
  isArchived  Boolean  @default(false)
  isPinned    Boolean  @default(false)
  color       String?  
  searchVector Unsupported("tsvector")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  files       NoteFile[]
  author      User          @relation(fields: [authorId], references: [id])
  blocks      NoteBlock[]
  versions    NoteVersion[]
  shares      NoteShare[]
  favorites   NoteFavorite[]
  
  @@index([authorId])
  @@index([folderId])
  @@index([isArchived])
  @@index([isPinned])
  @@index([searchVector], type: Gin)
  @@map("notes")
}

model NoteFavorite {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  createdAt DateTime @default(now())
  
  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([noteId, userId])
  @@index([userId])
  @@map("note_favorites")
}

enum NoteBlockType {
  PARAGRAPH
  HEADING_1
  HEADING_2
  HEADING_3
  BULLET_LIST
  NUMBERED_LIST
  TODO
  CODE
  QUOTE
  DIVIDER
  IMAGE
  FILE
  TABLE
  EMBED
  CALLOUT
}

model NoteBlock {
  id        String        @id @default(cuid())
  type      NoteBlockType
  content   Json
  position  Float         @default(0)
  noteId    String
  parentId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  note     Note    @relation(fields: [noteId], references: [id], onDelete: Cascade)
  parent   NoteBlock?  @relation("NoteBlockChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children NoteBlock[] @relation("NoteBlockChildren")
  
  @@index([noteId])
  @@index([parentId])
  @@map("note_blocks")
}

model NoteVersion {
  id        String   @id @default(cuid())
  noteId    String
  title     String
  content   Json
  version   Int
  authorId  String
  createdAt DateTime @default(now())

  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@unique([noteId, version])
  @@index([noteId])
  @@map("note_versions")
}

model NoteFile {
  id           String   @id @default(cuid())
  name         String
  originalName String
  mimeType     String
  size         Int
  url          String
  key          String  
  uploaderId   String
  noteId       String?  // Optional: link to specific note
  createdAt    DateTime @default(now())

  uploader User @relation(fields: [uploaderId], references: [id])
  note     Note? @relation(fields: [noteId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([noteId])
  @@map("note_files")
}

enum NoteShareType {
  VIEW
  COMMENT
  EDIT
}

model NoteShare {
  id          String      @id @default(cuid())
  token       String      @unique
  noteId      String
  type        NoteShareType @default(VIEW)
  expiresAt   DateTime?
  password    String?
  createdById String
  createdAt   DateTime    @default(now())

  note      Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([token])
  @@map("note_shares")
}

enum ScreenShareStatus {
  PENDING
  ACCEPTED
  REJECTED
  ACTIVE
  ENDED
}

model ScreenShareSession {
  id         String            @id @default(cuid())
  teamId     String
  adminId    String
  employeeId String
  status     ScreenShareStatus @default(PENDING)
  expiresAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  team       Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([employeeId])
  @@index([teamId, status])
  @@map("screen_share_sessions")
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt

  @@map("user_locations")
}

model ScheduledEmail {
  id                String   @id @default(cuid())
  userId            String
  to                String[]
  subject           String
  body              String   @db.Text
  cc                String[]
  bcc               String[]
  replyToMessageId  String?
  threadId          String?
  scheduledAt       DateTime
  sentAt            DateTime?
  status            String   @default("pending") // pending | sent | failed | cancelled
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([scheduledAt, status])
} 


model Room {
  id           String   @id @default(cuid())
  name         String
  slug         String
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User     @relation("RoomCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  thumbnailUrl String?
  isArchived   Boolean  @default(false)
  snapshot     String?  @db.Text

  @@unique([teamId, slug])
  @@index([teamId])
  @@index([createdById])
  @@map("rooms")
}

model MusicTrack {
  id            String   @id @default(cuid())
  title         String
  artist        String
  album         String?
  genre         String?
  duration      Int?     // in seconds
  coverImage    String?  // URL to cover art
  
  audioUrl      String   // S3/R2 public URL
  audioKey      String   @unique // S3/R2 object key
  originalName  String
  mimeType      String
  size          Int      // bytes
  
  uploadedById  String
  uploadedBy    User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  
  playlists     PlaylistTrack[]
  favourites    MusicFavourite[]
  
  playCount     Int      @default(0)
  isPublic      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([uploadedById])
  @@index([genre])
  @@index([createdAt])
  @@map("music_tracks")
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  coverImage  String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tracks      PlaylistTrack[]
  
  isPublic    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("playlists")
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  
  trackId    String
  track      MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  order      Int      @default(0)
  addedAt    DateTime @default(now())

  @@unique([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
  @@map("playlist_tracks")
}

model MusicFavourite {
  id        String   @id @default(cuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId   String
  track     MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
  @@map("favourites")
}

model VoiceAgentSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String   @default("idle") // idle, listening, processing, speaking
  messages    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("voice_agent_sessions")
}

model VoiceAgentReminder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // meeting, task, assignment, general
  title       String
  description String?
  metadata    Json?
  scheduledAt DateTime
  delivered   Boolean  @default(false)
  deliveredAt DateTime?
  acknowledged Boolean @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, scheduledAt])
  @@index([delivered])
  @@map("voice_agent_reminders")
}

model UserVoiceSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled           Boolean  @default(true)
  wakeWord          String   @default("hey conferio")
  voiceId           String   @default("21m00Tcm4TlvDq8ikWAM")
  proactiveEnabled  Boolean  @default(true)
  volume            Float    @default(1.0)
  language          String   @default("en")
  aiProvider        String   @default("openai") // openai, gemini, claude, ollama
  aiModel           String   @default("gpt-4o")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("user_voice_settings")
}


model MusicFavorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId    String   // JioSaavn id OR uploaded track id (prefixed "local:")
  type      MusicFavoriteType
  // denormalized snapshot for fast rendering without re-fetching JioSaavn
  title     String
  subtitle  String?
  image     String?

  createdAt DateTime @default(now())

  @@unique([userId, itemId, type])
  @@index([userId, type])
}

enum MusicFavoriteType {
  SONG
  ALBUM
  PLAYLIST
  ARTIST
  SHOW
}

model MusicPlaylist {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  coverImage  String?

  // array of track refs - JioSaavn ids OR "local:<uploadedTrackId>"
  songIds     String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model RecentlyPlayed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemId    String   // JioSaavn song id OR "local:<uploadedTrackId>"
  title     String
  subtitle  String?
  image     String?
  duration  Int?
  type      String   @default("song")
  playedAt  DateTime @default(now())

  @@index([userId, playedAt])
}

model UserMusicPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  languages String[] @default(["hindi", "english"])
  streamQuality String @default("excellent") // low | medium | high | excellent

  updatedAt DateTime @updatedAt
}

// User-uploaded tracks (stored on Cloudflare R2)
model UploadedTrack {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  artist      String?
  album       String?

  // R2 object keys
  audioKey    String   // e.g. music/<userId>/<id>.mp3
  imageKey    String?  // optional cover art

  duration    Int?     // seconds
  fileSize    Int?     // bytes
  mimeType    String   @default("audio/mpeg")

  isPublic    Boolean  @default(false) // visible to other users in search

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isPublic])
}

model RouteViewSession {
  id         String   @id @default(cuid())
  route      String
  routeLabel String?  @map("route_label")
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId     String   @map("team_id")
  team       Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  startedAt  DateTime @default(now()) @map("started_at")
  endedAt    DateTime? @map("ended_at")
  duration   Int?
  
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([route])
  @@index([userId])
  @@index([teamId])
  @@index([startedAt])
  @@map("route_view_sessions")
}

model RouteViewAggregate {
  id            String   @id @default(cuid())
  route         String
  routeLabel    String?  @map("route_label")
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId        String   @map("team_id")
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  
  totalDuration Int      @default(0) @map("total_duration")
  viewCount     Int      @default(1) @map("view_count")
  lastViewedAt  DateTime @default(now()) @map("last_viewed_at")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([route, userId])
  @@index([teamId])
  @@index([userId])
  @@index([route])
  @@map("route_view_aggregates")
}
