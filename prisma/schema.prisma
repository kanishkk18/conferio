  PUBLIC
}

model Page {
  id          String         @id @default(cuid())
  title       String         @default("Doc")
  content     Json?
  emoji       String?
  coverImage  String?
  parentId    String?
  workspaceId String
  authorId    String
  visibility  PageVisibility @default(WORKSPACE)
  position    Float          @default(0)
  isPublished Boolean        @default(false)
  publishedUrl String?       @unique
  searchVector Unsupported("tsvector")?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  notifications Notification[]
  
  parent    Page?    @relation("PageChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Page[]   @relation("PageChildren")
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  blocks    Block[]
  comments  Comment[]
  versions  PageVersion[]
  shares    Share[]

