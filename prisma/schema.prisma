enum CallStatus {
  PENDING
  CONNECTING
  ONGOING
  COMPLETED
  MISSED
  DECLINED
  FAILED
  ON_HOLD
}


enum CallType {
  AUDIO
  VIDEO
}

model Call {
  id              String     @id @default(cuid())
  callerId        String     @map("caller_id")
  calleeId        String?    @map("callee_id") // Nullable for group calls
  roomName        String     @unique @default(uuid())
  status          CallStatus @default(PENDING)
  type            CallType   @default(AUDIO)
  isGroupCall     Boolean    @default(false)
  
  // For simultaneous calls / merging
  parentCallId    String?    @map("parent_call_id")
  parentCall      Call?      @relation("MergedCalls", fields: [parentCallId], references: [id])
  childCalls      Call[]     @relation("MergedCalls")
  isOnHold        Boolean    @default(false)
  
  startedAt       DateTime?  @map("started_at")
  endedAt         DateTime?  @map("ended_at")
  duration        Int?       // Duration in seconds
  
  // Relations
  caller          User       @relation("Caller", fields: [callerId], references: [id])
  callee          User?      @relation("Callee", fields: [calleeId], references: [id])
  participants    CallParticipant[]
  recordings      CallRecording[]
  notifications   Notification[]
  whiteboardData  Json?      @map("whiteboard_data")
  annotations     Json[]     // Screen share annotations
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime @updatedAt @default(now())

  @@index([callerId])
  @@index([calleeId])
  @@index([status])
  @@index([roomName])
  @@map("calls")
}

model CallParticipant {
  id          String   @id @default(cuid())
  callId      String
  userId      String
  joinedAt    DateTime @default(now())
  leftAt      DateTime?
  isMuted     Boolean  @default(false)
  isVideoOn   Boolean  @default(true)
  isScreenSharing Boolean @default(false)
  
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  
  @@unique([callId, userId])
  @@map("call_participants")
}

model CallRecording {
  id          String   @id @default(cuid())
  callId      String   @map("call_id")
  recordedBy  String   @map("recorded_by") // User who initiated recording
  
  url         String
  filename    String
  size        Int?     // File size in bytes
  duration    Int?     // Recording duration in seconds
  format      String   @default("webm") // webm, mp3, etc.
  
  createdAt   DateTime @default(now()) @map("created_at")
  
  call        Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [recordedBy], references: [id])
  
  @@index([callId])
  @@map("call_recordings")
}

